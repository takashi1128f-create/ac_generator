{
	"name": "ac-file-generator",
	"version": "0.0.6",
	"description": "Assetto Corsa File Generator",
	"author": "nerutakachan",
	"main": "main-electron.js",
	"scripts": {
		"start": "chcp 65001 && nodemon --watch main-electron.js --watch preload.js --exec electron .",
		"build": "electron-builder --win"
	},
	"devDependencies": {
		"electron": "^28.3.3",
		"electron-builder": "^24.13.3",
		"electron-reload": "^2.0.0-alpha.1",
		"nodemon": "^3.1.14"
	},
	"build": {
		"appId": "com.example.ac-file-generator",
		"productName": "AC FILE GENERATOR",
		"publish": [
			{
				"provider": "github",
				"owner": "takashi1128f-create",
				"repo": "ac_generator"
			}
		],
		"win": {
			"target": "nsis",
			"icon": "image/icon.ico",
			"requestedExecutionLevel": "asInvoker",
			"artifactName": "AC-FILE-GENERATOR-Setup.exe"
		},
		"nsis": {
			"oneClick": false,
			"perMachine": true,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"shortcutName": "AC FILE GENERATOR"
		}
	},
	"dependencies": {
		"electron-updater": "^6.8.9"
	}
}
